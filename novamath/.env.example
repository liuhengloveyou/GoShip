CONTENT_SOURCE=local

# When CONTENT_SOURCE=gopress, Astro will fetch published posts from GoPress API.
# Example:
# GOPRESS_API_BASE=http://127.0.0.1:8080
# GOPRESS_API_TOKEN=
#
# When CONTENT_SOURCE=pb, Astro will fetch published posts from PocketBase.
# Example:
# POCKETBASE_URL=http://127.0.0.1:8090
# POCKETBASE_POSTS_COLLECTION=posts
# POCKETBASE_API_TOKEN=

