---
import type { HTMLAttributes } from "astro/types";
import { SITE } from "@/config";
import LogoMark from "./LogoMark.astro";

type Props = {
  href?: string;
  size?: "sm" | "md";
} & HTMLAttributes<"a">;

const {
  href = "/",
  size = "md",
  class: className,
  ...attrs
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "inline-flex items-center gap-2 font-semibold tracking-tight leading-none",
    { "text-lg": size === "sm", "text-xl": size === "md" },
    className,
  ]}
  style="color: var(--color-ink);"
  {...attrs}
>
  <LogoMark size={size} />
  <span>{SITE.title}</span>
</a>
