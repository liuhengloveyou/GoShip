---
import type { HTMLAttributes } from "astro/types";
import { SITE } from "@/config";
import LogoMark from "./LogoMark.astro";

type Props = {
  href?: string;
  size?: "sm" | "md";
} & HTMLAttributes<"a">;

const {
  href = "/",
  size = "md",
  class: className,
  ...attrs
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "site-brand inline-flex items-center gap-2 font-semibold tracking-tight leading-none transition-opacity hover:opacity-80",
    { "h-7 text-lg": size === "sm" },
    { "h-8 text-xl": size === "md" },
    className,
  ]}
  style="color: var(--landing-ink, inherit);"
  {...attrs}
>
  <LogoMark size={size} />
  <span class="inline-block leading-none">{SITE.title}</span>
</a>
