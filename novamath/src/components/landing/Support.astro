---
import { SITE } from "@/config";
---

<section id="support" class="support-section">
  <div class="landing-container">
    <div class="cta-band mx-auto max-w-2xl">
      <h2 class="display-sm">需要支持？</h2>
      <p class="body-md mx-auto mt-3 max-w-md">
        遇到问题或有功能建议？欢迎联系我们，我们会尽快回复。
      </p>
      <a href={`mailto:${SITE.contact.email}`} class="btn-primary mt-8">
        联系支持
      </a>
      <p class="caption mt-4">{SITE.contact.email}</p>
    </div>
  </div>
</section>
