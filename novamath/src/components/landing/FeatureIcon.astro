---
import type { FeatureIcon } from "@/data/landing";

type Props = { name: FeatureIcon };

const { name } = Astro.props;
---

{
  name === "zap" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-5" aria-hidden="true">
      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "code" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-5" aria-hidden="true">
      <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "palette" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-5" aria-hidden="true">
      <path d="M12 2a10 10 0 1 0 0 20c1.5 0 2-1 2-2.5 0-.8-.5-1.5-1-2-.5-.5-1-1.2-1-2 0-1.7 1.3-3 3-3h1.5c2.5 0 4.5-2 4.5-4.5A10 10 0 0 0 12 2z" stroke-linecap="round" />
      <circle cx="7.5" cy="10" r="1" fill="currentColor" />
      <circle cx="10" cy="7" r="1" fill="currentColor" />
      <circle cx="14" cy="7" r="1" fill="currentColor" />
    </svg>
  )
}
{
  name === "scan" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-5" aria-hidden="true">
      <path d="M4 7V4h3M20 7V4h-3M4 17v3h3M20 17v3h-3" stroke-linecap="round" />
      <rect x="7" y="7" width="10" height="10" rx="1" />
    </svg>
  )
}
{
  name === "symbol" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-5" aria-hidden="true">
      <path d="M4 12h16M12 4v16" stroke-linecap="round" />
      <circle cx="12" cy="12" r="9" />
    </svg>
  )
}
