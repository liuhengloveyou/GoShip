---
import { SITE } from "@/config";
import { navItems } from "@/data/landing";

const currentYear = new Date().getFullYear();
---

<footer class="landing-footer">
  <div class="landing-container">
    <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-3">
        <a href="/" class="brand-text text-xl font-semibold tracking-tight">
          {SITE.title}
        </a>
        <p class="landing-footer-desc max-w-xs">{SITE.desc}</p>
      </div>
      <nav aria-label="页脚导航">
        <ul class="flex flex-wrap gap-x-6 gap-y-2">
          {
            navItems.map(item => (
              <li>
                <a href={item.href} class="landing-footer-link">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
    <div class="landing-footer-divider flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
      <span>Copyright © {currentYear} {SITE.title}</span>
      <span>保留所有权利</span>
    </div>
  </div>
</footer>
