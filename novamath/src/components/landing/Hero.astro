---
import { SITE } from "@/config";
import { platforms, heroHighlights } from "@/data/landing";
---

<section class="hero-section">
  <div class="landing-container">
    <div class="hero-grid">
      <div class="min-w-0">
        <span class="badge-pill">AI 驱动的数学工具</span>

        <h1 class="display-xl mt-5 text-balance">
          数学公式<br />识别与编辑
        </h1>

        <p class="body-md mt-5 max-w-md">{SITE.desc}</p>

        <div class="hero-highlights">
          {heroHighlights.map(item => <span class="badge-pill">{item}</span>)}
        </div>

        <div id="download" class="mt-8 flex flex-col items-start gap-4">
          <div class="nav-pill-group" role="tablist" aria-label="选择平台">
            {
              platforms.map((platform, index) => (
                <button
                  type="button"
                  class:list={[
                    "platform-tab",
                    { "platform-tab-active": index === 0 },
                  ]}
                  data-platform={platform.id}
                  aria-selected={index === 0 ? "true" : "false"}
                >
                  {platform.label}
                </button>
              ))
            }
          </div>
          <a href={SITE.download.macos} id="download-btn" class="btn-primary">
            下载 macOS 版
            <svg viewBox="0 0 20 20" fill="currentColor" class="size-4" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <figure class="hero-mockup min-w-0">
        <img
          src="/media/hero-editor.svg"
          alt="NovaMath 公式编辑器界面预览"
          width="800"
          height="520"
          class="block h-auto w-full"
          loading="eager"
        />
      </figure>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>("[data-platform]");
  const downloadBtn = document.getElementById("download-btn");

  const labels: Record<string, string> = {
    macos: "下载 macOS 版",
    windows: "下载 Windows 版",
    linux: "下载 Linux 版",
  };

  tabs.forEach(tab => {
    tab.addEventListener("click", () => {
      const platform = tab.dataset.platform;
      if (!platform) return;

      tabs.forEach(t => {
        const active = t === tab;
        t.classList.toggle("platform-tab-active", active);
        t.setAttribute("aria-selected", active ? "true" : "false");
      });

      if (downloadBtn && labels[platform]) {
        downloadBtn.childNodes[0].textContent = labels[platform] + " ";
      }
    });
  });
</script>
