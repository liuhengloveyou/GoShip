---
import { useCases } from "@/data/landing";
---

<section class="testimonials-section">
  <div class="landing-container">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="display-lg">用户评价</h2>
      <p class="body-md mt-3">来自高校师生与科研工作者的使用反馈</p>
    </div>

    <ul class="testimonial-grid mt-12">
      {
        useCases.map(item => (
          <li class="testimonial-card">
            <div class="testimonial-header">
              <span class:list={["avatar-circle", `avatar-${item.avatar}`]}>
                {item.initials}
              </span>
              <span class="caption">{item.role}</span>
            </div>
            <blockquote class="testimonial-text">{item.quote}</blockquote>
          </li>
        ))
      }
    </ul>
  </div>
</section>
