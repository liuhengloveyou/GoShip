---
import { featureGroups } from "@/data/landing";
import FeatureIcon from "./FeatureIcon.astro";
---

{
  featureGroups.map((group, index) => (
    <section
      id={index === 0 ? "features" : group.id}
      class:list={[index % 2 === 0 ? "features-section" : "features-section-alt"]}
    >
      <div class="landing-container">
        <div class="feature-group-header">
          <p class="caption uppercase tracking-widest">{group.number}</p>
          <h2 class="display-lg mt-2">{group.title}</h2>
          <p class="body-md mt-3">{group.description}</p>
        </div>

        <ul
          class:list={[
            "feature-grid",
            group.items.length === 3 ? "feature-grid-3" : "feature-grid-2",
          ]}
        >
          {group.items.map(item => (
            <li class="feature-card">
              <div class="feature-card-icon">
                <FeatureIcon name={item.icon} />
              </div>
              <h3 class="feature-card-title">{item.title}</h3>
              <p class="feature-card-desc">{item.description}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))
}
