---
type Props = {
  size?: "sm" | "md";
};

const { size = "md" } = Astro.props;
---

<span
  class:list={[
    "inline-flex shrink-0 items-center justify-center rounded-md bg-neutral-900 text-white dark:bg-white dark:text-neutral-900",
    { "size-5": size === "sm", "size-6": size === "md" },
  ]}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 24 24"
    fill="none"
    class:list={[{ "size-3": size === "sm", "size-3.5": size === "md" }]}
  >
    <path
      d="M6 18L18 6M8 6h10v10"
      stroke="currentColor"
      stroke-width="2.25"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</span>
