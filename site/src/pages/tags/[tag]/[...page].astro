---
import { getPublishedPosts } from "@/content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";
import { t } from "@/i18n/ui";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedPosts();
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
const locale = Astro.currentLocale ?? SITE.lang;
const tagDesc = t(locale, "tagArticles").replace("{tag}", tagName);
---

<Layout title={`${t(locale, "tag")}: ${tagName} | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle={[`${t(locale, "tag")}:`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={tagDesc}
  >
    <h1 slot="title" transition:name={tag}>{`${t(locale, "tag")}:${tag}`}</h1>
    <ul class="space-y-4">
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
