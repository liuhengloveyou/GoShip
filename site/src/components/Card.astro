---
import type { BlogPost } from "@/content";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & BlogPost;

const { variant: Heading = "h2", data, permalink } = Astro.props;

const { title, description, ...props } = data;
---

<li>
  <a
    href={permalink}
    class:list={[
      "card border border-base-300 bg-base-100 transition-all hover:-translate-y-0.5 hover:shadow-md",
      "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40",
    ]}
  >
    <div class="card-body gap-2 p-5">
      <Heading
        class="card-title text-lg font-semibold text-primary"
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
      <Datetime {...props} />
      <p class="text-sm leading-6 text-base-content/75">{description}</p>
    </div>
  </a>
</li>
