---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { t } from "@/i18n/ui";

type NavItem = {
  label: string;
  href: string;
  active?: boolean;
};

type Props = {
  navItems?: NavItem[];
};

const { navItems = [] } = Astro.props;
const locale = Astro.currentLocale ?? SITE.lang;
---

<div class="min-h-screen bg-base-100 text-base-content">
  <Header />

  <!-- Mobile -->
  <div class="drawer lg:hidden">
    <input id="docs-drawer" type="checkbox" class="drawer-toggle" />
    <div class="drawer-content min-h-[calc(100vh-4rem)]">
      <div class="px-4 pt-4">
        <label for="docs-drawer" class="btn btn-outline btn-sm">
          {t(locale, "openNavigation")}
        </label>
      </div>
      <main id="main-content" class="mx-auto w-full max-w-4xl px-4 py-6">
        <slot />
      </main>
    </div>
    <aside class="drawer-side z-30">
      <label for="docs-drawer" class="drawer-overlay" aria-label="Close menu"></label>
      <div class="min-h-full w-64 border-r border-base-300 bg-base-100">
        <div class="sticky top-0 h-screen overflow-y-auto p-4">
          <ul class="menu gap-1">
            <li class="menu-title"><span>{t(locale, "navTitle")}</span></li>
            {
              navItems.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={["side-nav-link", { "is-active": item.active }]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </aside>
  </div>

  <!-- Desktop -->
  <div class="hidden lg:block">
    <div class="mx-auto grid w-full max-w-7xl grid-cols-[17rem_minmax(0,1fr)] gap-8 px-4 py-8 xl:px-6">
      <aside class="border-r border-base-300 pr-4">
        <div class="sticky top-20 overflow-y-auto">
          <ul class="menu gap-1">
            <li class="menu-title"><span>{t(locale, "navTitle")}</span></li>
            {
              navItems.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={["side-nav-link", { "is-active": item.active }]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </aside>
      <main id="main-content" class="max-w-4xl">
        <slot />
      </main>
    </div>
  </div>

  <Footer />
</div>
